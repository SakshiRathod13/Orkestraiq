generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum EventType {
  WORKSHOP
  WEBINAR
  TRAINING
  BOOTCAMP
  COLLEGE_FEST
  ORIENTATION
  PAID_CLASS
  MEETUP
  OTHER
}

enum EventStatus {
  DRAFT
  PLANNING
  READY
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum EventBriefStatus {
  DRAFT
  APPROVED
}

enum AgentName {
  COO
  EVENT_PLANNER
  FORM
  LANDING_PAGE
  MARKETING
  DESIGN
  MEETING
  ANALYTICS
  DOCUMENTATION
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum AgentApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_REQUIRED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  name          String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  memberships   OrganizationMember[]
  createdEvents Event[]              @relation("CreatedEvents")
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     OrganizationMember[]
  events      Event[]
  agentRuns   AgentRun[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole   @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Event {
  id             String        @id @default(cuid())
  organizationId String
  createdById    String?
  title          String
  slug           String
  description    String?
  type           EventType     @default(WORKSHOP)
  status         EventStatus   @default(DRAFT)
  timezone       String        @default("Asia/Kolkata")
  startAt        DateTime?
  endAt          DateTime?
  venue          String?
  onlineUrl      String?
  audience       String?
  objective      String?
  capacity       Int?
  priceCents     Int?
  currency       String        @default("INR")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?         @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: SetNull)
  brief          EventBrief?
  agentRuns      AgentRun[]
  landingPage    LandingPage?
  registrationForm RegistrationForm?
  marketingDraft MarketingDraft?
  attendees      Attendee[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([type])
}

model MarketingDraft {
  id                  String              @id @default(cuid())
  eventId             String              @unique
  approvalStatus      AgentApprovalStatus @default(PENDING)
  emailCampaign       Json
  whatsappMessages    Json
  linkedInPost        Json
  instagramCaption    Json
  reminderSequence    Json
  posterPrompt        Json
  certificateTemplate Json
  approvedAt          DateTime?
  approvedBy          String?
  rejectedAt          DateTime?
  rejectedBy          String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  event               Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([approvalStatus])
}

model LandingPage {
  id             String        @id @default(cuid())
  eventId        String        @unique
  status         PublishStatus @default(PUBLISHED)
  hero           Json
  problem        Json
  outcomes       Json
  agenda         Json
  speaker        Json
  benefits       Json
  certificate    Json
  pricing        Json
  faqs           Json
  cta            Json
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}

model RegistrationForm {
  id          String        @id @default(cuid())
  eventId     String        @unique
  status      PublishStatus @default(PUBLISHED)
  title       String
  description String?
  fields      Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Attendee {
  id             String   @id @default(cuid())
  eventId        String
  organizationId String
  name           String
  email          String
  phone          String?
  responses      Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([organizationId])
  @@unique([eventId, email])
}

model AgentRun {
  id              String              @id @default(cuid())
  organizationId  String
  eventId         String?
  agentName       AgentName
  status          AgentRunStatus      @default(QUEUED)
  approvalStatus  AgentApprovalStatus @default(PENDING)
  input           Json
  output          Json?
  error           String?
  attempt         Int                 @default(1)
  retryOfId       String?
  requiresApproval Boolean            @default(true)
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  createdAt       DateTime            @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event           Event?              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  retryOf         AgentRun?           @relation("AgentRunRetries", fields: [retryOfId], references: [id], onDelete: SetNull)
  retries         AgentRun[]          @relation("AgentRunRetries")

  @@index([organizationId])
  @@index([eventId])
  @@index([agentName])
  @@index([status])
  @@index([approvalStatus])
}

model EventBrief {
  id              String           @id @default(cuid())
  eventId         String           @unique
  originalPrompt  String
  status          EventBriefStatus @default(DRAFT)
  eventType       EventType?
  topic           String?
  targetAudience  String?
  mode            String?
  location        String?
  dateTimeText    String?
  durationMinutes Int?
  priceCents      Int?
  currency        String           @default("INR")
  targetAttendees Int?
  language        String?
  tone            String?
  goal            String?
  missingFields   Json             @default("[]")
  missingQuestions Json            @default("[]")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}
