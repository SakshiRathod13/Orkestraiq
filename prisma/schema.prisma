generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum EventType {
  WORKSHOP
  WEBINAR
  TRAINING
  BOOTCAMP
  COLLEGE_FEST
  ORIENTATION
  PAID_CLASS
  MEETUP
  OTHER
}

enum EventStatus {
  DRAFT
  PLANNING
  READY
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum EventBriefStatus {
  DRAFT
  APPROVED
}

enum AgentName {
  COO
  EVENT_PLANNER
  FORM
  LANDING_PAGE
  MARKETING
  DESIGN
  MEETING
  ANALYTICS
  DOCUMENTATION
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum AgentApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_REQUIRED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum CampaignStatus {
  DRAFT
  APPROVAL_REQUIRED
  APPROVED
  SCHEDULED
  SENT
  CANCELLED
}

enum MessageChannel {
  EMAIL
  WHATSAPP
  LINKEDIN
  INSTAGRAM
  SMS
}

enum MessageStatus {
  DRAFT
  APPROVAL_REQUIRED
  APPROVED
  QUEUED
  SENT
  FAILED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum MeetingProvider {
  GOOGLE_MEET
  ZOOM
  OFFLINE
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum IntegrationProvider {
  GMAIL
  GOOGLE_CALENDAR
  GOOGLE_MEET
  ZOOM
  RAZORPAY
  STRIPE
  WHATSAPP_BUSINESS
}

enum IntegrationStatus {
  NOT_CONFIGURED
  CONFIGURED
  NEEDS_REAUTH
  DISABLED
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  name          String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  memberships   OrganizationMember[]
  createdEvents Event[]              @relation("CreatedEvents")
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     OrganizationMember[]
  events      Event[]
  agentRuns   AgentRun[]
  integrations Integration[]
  auditLogs   AuditLog[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole   @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Event {
  id             String        @id @default(cuid())
  organizationId String
  createdById    String?
  title          String
  slug           String
  description    String?
  type           EventType     @default(WORKSHOP)
  status         EventStatus   @default(DRAFT)
  timezone       String        @default("Asia/Kolkata")
  startAt        DateTime?
  endAt          DateTime?
  venue          String?
  onlineUrl      String?
  audience       String?
  objective      String?
  capacity       Int?
  priceCents     Int?
  currency       String        @default("INR")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?         @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: SetNull)
  brief          EventBrief?
  agentRuns      AgentRun[]
  landingPage    LandingPage?
  registrationForm RegistrationForm?
  marketingDraft MarketingDraft?
  attendees      Attendee[]
  campaigns      Campaign[]
  messageLogs    MessageLog[]
  payments       Payment[]
  meeting        Meeting?
  tasks          Task[]
  analyticsSnapshots AnalyticsSnapshot[]
  auditLogs      AuditLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([type])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  eventId        String
  name           String
  status         CampaignStatus @default(DRAFT)
  channel        MessageChannel
  draftContent   Json
  approvedAt     DateTime?
  approvedBy     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  messages       MessageLog[]

  @@index([organizationId])
  @@index([eventId])
  @@index([status])
  @@index([channel])
}

model MessageLog {
  id             String         @id @default(cuid())
  organizationId String
  eventId        String
  campaignId     String?
  channel        MessageChannel
  status         MessageStatus  @default(DRAFT)
  recipient      String?
  subject        String?
  body           String
  provider       IntegrationProvider?
  providerMessageId String?
  error          String?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  campaign       Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([eventId])
  @@index([campaignId])
  @@index([status])
  @@index([channel])
}

model Payment {
  id                String          @id @default(cuid())
  organizationId    String
  eventId           String
  attendeeId        String?
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  amountCents       Int
  currency          String          @default("INR")
  providerPaymentId String?
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  event             Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([eventId])
  @@index([attendeeId])
  @@index([provider])
  @@index([status])
}

model Meeting {
  id             String          @id @default(cuid())
  organizationId String
  eventId        String          @unique
  provider       MeetingProvider
  title          String
  joinUrl        String?
  calendarEventId String?
  startAt        DateTime?
  endAt          DateTime?
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([provider])
}

model Task {
  id             String     @id @default(cuid())
  organizationId String
  eventId        String?
  title          String
  description    String?
  owner          String?
  status         TaskStatus @default(TODO)
  dueAt          DateTime?
  sourceAgentRunId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  event          Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([eventId])
  @@index([status])
}

model AnalyticsSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  eventId        String
  metrics        Json
  createdAt      DateTime @default(now())
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([eventId])
  @@index([createdAt])
}

model Integration {
  id             String              @id @default(cuid())
  organizationId String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(NOT_CONFIGURED)
  config         Json                @default("{}")
  credentialRef  String?
  lastCheckedAt  DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([status])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  eventId        String?
  actorId        String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([eventId])
  @@index([action])
  @@index([createdAt])
}

model MarketingDraft {
  id                  String              @id @default(cuid())
  eventId             String              @unique
  approvalStatus      AgentApprovalStatus @default(PENDING)
  emailCampaign       Json
  whatsappMessages    Json
  linkedInPost        Json
  instagramCaption    Json
  reminderSequence    Json
  posterPrompt        Json
  certificateTemplate Json
  approvedAt          DateTime?
  approvedBy          String?
  rejectedAt          DateTime?
  rejectedBy          String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  event               Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([approvalStatus])
}

model LandingPage {
  id             String        @id @default(cuid())
  eventId        String        @unique
  status         PublishStatus @default(PUBLISHED)
  hero           Json
  problem        Json
  outcomes       Json
  agenda         Json
  speaker        Json
  benefits       Json
  certificate    Json
  pricing        Json
  faqs           Json
  cta            Json
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}

model RegistrationForm {
  id          String        @id @default(cuid())
  eventId     String        @unique
  status      PublishStatus @default(PUBLISHED)
  title       String
  description String?
  fields      Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Attendee {
  id             String   @id @default(cuid())
  eventId        String
  organizationId String
  name           String
  email          String
  phone          String?
  source         String   @default("direct")
  responses      Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([organizationId])
  @@index([source])
  @@unique([eventId, email])
}

model AgentRun {
  id              String              @id @default(cuid())
  organizationId  String
  eventId         String?
  agentName       AgentName
  status          AgentRunStatus      @default(QUEUED)
  approvalStatus  AgentApprovalStatus @default(PENDING)
  input           Json
  output          Json?
  error           String?
  attempt         Int                 @default(1)
  retryOfId       String?
  requiresApproval Boolean            @default(true)
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  createdAt       DateTime            @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event           Event?              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  retryOf         AgentRun?           @relation("AgentRunRetries", fields: [retryOfId], references: [id], onDelete: SetNull)
  retries         AgentRun[]          @relation("AgentRunRetries")

  @@index([organizationId])
  @@index([eventId])
  @@index([agentName])
  @@index([status])
  @@index([approvalStatus])
}

model EventBrief {
  id              String           @id @default(cuid())
  eventId         String           @unique
  originalPrompt  String
  status          EventBriefStatus @default(DRAFT)
  eventType       EventType?
  topic           String?
  targetAudience  String?
  mode            String?
  location        String?
  dateTimeText    String?
  durationMinutes Int?
  priceCents      Int?
  currency        String           @default("INR")
  targetAttendees Int?
  language        String?
  tone            String?
  goal            String?
  missingFields   Json             @default("[]")
  missingQuestions Json            @default("[]")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}
